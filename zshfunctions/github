#!/usr/bin/env zsh

github_normalize_remote_url () {
  local giturl="$1"
  local base_url="$giturl"

  if [[ "$base_url" == git@github.com:* ]]; then
    base_url="${base_url/git@github.com:/https://github.com/}"
    base_url="${base_url%.git}"
    echo "$base_url"
    return 0
  fi

  if [[ "$base_url" == https://github.com/* ]]; then
    base_url="${base_url%.git}"
    echo "$base_url"
    return 0
  fi

  if [[ "$base_url" == git@gist.github.com:* ]]; then
    local gistid
    gistid="$(echo "$base_url" | sed 's/.*://;s/.git//')"
    echo "https://gist.github.com/$gistid"
    return 0
  fi

  return 1
}

github_open_project () {
  local repo_root="$1"
  local wingman_config="$repo_root/.wingman/config/wingman.json"

  if [[ ! -f "$wingman_config" ]]; then
    echo "No Wingman config found at: $wingman_config"
    return 1
  fi

  if ! command -v jq >/dev/null 2>&1; then
    echo "jq is not installed."
    return 1
  fi

  if ! command -v gh >/dev/null 2>&1; then
    echo "gh is not installed."
    return 1
  fi

  local owner
  local project_name
  local project_url

  owner="$(jq -r '.issues.github.owner // empty' < "$wingman_config")"
  project_name="$(jq -r '.issues.github.projectName // empty' < "$wingman_config")"

  if [[ -z "$owner" || -z "$project_name" ]]; then
    echo "Missing .issues.github.owner or .issues.github.projectName in $wingman_config"
    return 1
  fi

  project_url="$(
    gh api graphql \
      -f query='
        query($login: String!) {
          organization(login: $login) {
            projectsV2(first: 100) {
              nodes {
                title
                url
              }
            }
          }
        }
      ' \
      -F login="$owner" \
      2>/dev/null \
    | jq -r --arg project_name "$project_name" '
        .data.organization.projectsV2.nodes[]
        | select(.title == $project_name)
        | .url
      ' \
    | head -n 1
  )"

  if [[ -z "$project_url" ]]; then
    echo "Could not find GitHub project named '$project_name' for owner '$owner'."
    return 1
  fi

  echo "$project_url"
  command open "$project_url"
}

local target="${1:-.}"

if ! command -v git >/dev/null 2>&1; then
  echo "git is not installed."
  return 1
fi

local repo_root
repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "Not a git repository."
  return 1
}

if [[ "$target" == "project" ]]; then
  github_open_project "$repo_root"
  return $?
fi

local giturl
giturl="$(git config --get remote.origin.url)"
if [[ -z "$giturl" ]]; then
  echo "No remote.origin.url set."
  return 1
fi

local base_url
base_url="$(github_normalize_remote_url "$giturl")"
if [[ -z "$base_url" ]]; then
  echo "Unsupported remote.origin.url: $giturl"
  return 1
fi

local branch
branch="$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null | sed 's|^[^/]*/||')"
if [[ -z "$branch" ]]; then
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"
fi
[[ -z "$branch" ]] && branch="HEAD"

local path_part="$target"
local line_fragment=""

if [[ "$target" == *:* ]]; then
  local after_colon="${target##*:}"
  local before_colon="${target%:*}"

  if [[ "$after_colon" == <-> ]]; then
    path_part="$before_colon"
    line_fragment="#L$after_colon"
  elif [[ "$after_colon" == <->-<-> ]]; then
    path_part="$before_colon"
    line_fragment="#L${after_colon%-*}-L${after_colon#*-}"
  fi
fi

local abs_path
if [[ "$path_part" == "." ]]; then
  abs_path="$repo_root"
elif [[ "$path_part" == ".." ]]; then
  abs_path="$(cd "$repo_root/.." 2>/dev/null && pwd -P)"
elif [[ -e "$path_part" ]]; then
  abs_path="$(cd -P -- "$(dirname -- "$path_part")" 2>/dev/null && pwd -P)/$(basename -- "$path_part")"
else
  abs_path="$repo_root/$path_part"
fi

local rel_path=""
if [[ "$abs_path" != "$repo_root" ]]; then
  rel_path="${abs_path#$repo_root/}"
fi

local url
if [[ -z "$rel_path" ]]; then
  url="$base_url"
elif [[ -d "$abs_path" ]]; then
  url="$base_url/tree/$branch/$rel_path"
else
  url="$base_url/blob/$branch/$rel_path$line_fragment"
fi

echo "$url"
command open "$url"
